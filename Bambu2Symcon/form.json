{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "MQTT Verbindung",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "PrinterSerial",
          "caption": "Drucker Seriennummer"
        },
        {
          "type": "ValidationTextBox",
          "name": "MqttTopic",
          "caption": "MQTT Topic"
        },
        {
          "type": "Label",
          "caption": "Standard: device/{SERIAL}/report. {SERIAL} wird durch die Drucker-Seriennummer ersetzt."
        },
        {
          "type": "ValidationTextBox",
          "name": "ClientID",
          "caption": "Client ID"
        },
        {
          "type": "ValidationTextBox",
          "name": "UserName",
          "caption": "Benutzername"
        },
        {
          "type": "Select",
          "name": "MqttProtocolLevel",
          "caption": "MQTT Protokoll",
          "options": [
            { "caption": "MQTT 3.1.1", "value": 4 },
            { "caption": "MQTT 3.1", "value": 3 }
          ]
        },
        {
          "type": "PasswordTextBox",
          "name": "Password",
          "caption": "Passwort / Access Code"
        },
        {
          "type": "NumberSpinner",
          "name": "KeepAliveInterval",
          "caption": "KeepAlive Intervall",
          "suffix": "Sekunden",
          "minimum": 15,
          "maximum": 300
        },
        {
          "type": "CheckBox",
          "name": "AutoConnect",
          "caption": "Beim Anwenden automatisch verbinden"
        },
        {
          "type": "CheckBox",
          "name": "AutoSubscribe",
          "caption": "Nach Verbindung automatisch abonnieren"
        },
        {
          "type": "CheckBox",
          "name": "AutoReconnect",
          "caption": "Verbindung bei ausbleibenden Daten automatisch neu aufbauen"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Daten",
      "items": [
        {
          "type": "CheckBox",
          "name": "CreateStatusVariables",
          "caption": "Statusvariablen unterhalb der Instanz anlegen"
        },
        {
          "type": "CheckBox",
          "name": "ShowAdvancedMetrics",
          "caption": "Zusatzwerte in grosser Kachel anzeigen"
        },
        {
          "type": "CheckBox",
          "name": "ShowAmsFilaments",
          "caption": "AMS Filamente in grosser Kachel anzeigen"
        },
        {
          "type": "CheckBox",
          "name": "ShowAmsRemaining",
          "caption": "AMS Restmengen anzeigen"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Kachel",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "TileTitle",
          "caption": "Titel"
        },
        {
          "type": "Select",
          "name": "AccentColor",
          "caption": "Akzentfarbe",
          "options": [
            { "caption": "IP-Symcon Blau", "value": "symcon" },
            { "caption": "Hellblau", "value": "lightblue" },
            { "caption": "Gruen", "value": "green" },
            { "caption": "Orange", "value": "orange" }
          ]
        },
        {
          "type": "Select",
          "name": "ProgressRingSize",
          "caption": "Fortschrittskreis",
          "options": [
            { "caption": "Kompakt", "value": "small" },
            { "caption": "Standard", "value": "medium" },
            { "caption": "Gross", "value": "large" }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "MQTT verbinden",
      "onClick": "BAMBU_ConnectMqtt($id);"
    },
    {
      "type": "Button",
      "caption": "Topic abonnieren",
      "onClick": "BAMBU_SubscribeMqtt($id);"
    },
    {
      "type": "Label",
      "caption": "Die Instanz wird direkt mit einer Client-Socket-IO-Instanz verbunden und spricht MQTT selbst. Als Fallback koennen Rohpayloads weiterhin per BAMBU_ProcessPayload($instanceID, $payload) uebergeben werden."
    }
  ]
}
