        },
        {
          "type": "CheckBox",
          "name": "ShowAdvancedMetrics",
          "caption": "Zusatzwerte in grosser Kachel anzeigen"
        },
        {
          "type": "CheckBox",
          "name": "ShowAmsFilaments",
          "caption": "AMS Filamente in grosser Kachel anzeigen"
        },
        {
          "type": "CheckBox",
          "name": "ShowAmsRemaining",
          "caption": "AMS Restmengen anzeigen"
        }
      ]
